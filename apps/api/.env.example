PORT=3040
# xAI / Grok (OpenAI-compatible SDK)
GROK_API_KEY=
GROK_API_URL=https://api.x.ai/v1
GROK_TEXT_MODEL=grok-4-1-fast-non-reasoning
GROK_IMAGE_MODEL=grok-imagine-image

# Dossier de sortie (absolu ou relatif au cwd ; défaut: ../../content/generated/arbre-de-vie depuis apps/api)
# CONTENT_GENERATED_DIR=

# Sources pour POST /site/generate-game-context (autre jeu : pointer vers tes dossiers)
# GAME_CARDS_CONTEXT_DIR=   # .md par carte (défaut : oseunpasverstoi-jeux1/.../contexts/cards)
# GAME_BOOKLET_DIR=         # livret .md (défaut : oseunpasverstoi-jeux1/.../booklet)
# GROK_GAME_CONTEXT_MODEL=  # optionnel ; sinon GROK_TEXT_MODEL

# Redis — requis pour POST /ai/generate-markdown-async
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# ou une seule URL :
# REDIS_URL=redis://127.0.0.1:6379
# REDIS_PASSWORD=
